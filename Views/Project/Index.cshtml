@* indicates that the view expects alist of projects as its model *@
@model List<Project>

@{
    ViewBag.Title = "List of projects";
    Layout = "_Layout";
}

<h2>Projects Listing</h2>

@if (Model.Any())
{
    //iteration
    <table class="table">
        <thead>
        
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Description</th>
            </tr>
        
        </thead>
        
        <tbody>
        
        @foreach (var project in Model)
        {
            <tr>
                <td>@project.ProjectId</td>
                <td>@project.Name</td>
                <td>@project.Description</td>
            </tr>
        }
        </tbody>
  </table>
}
else
{
    <p>No projects available</p>
}
